{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Delta",
  "version": "1.0.0",
  "identifier": "com.nileagi.delta",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": "pnpm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Delta",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/delta-server",
      "binaries/llama-server"
    ],
    "resources": {
      "../public": "webui"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsi"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
